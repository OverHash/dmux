{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    "frontend/dist/**",
    "frontend/template-*.html",
    ".dmux/**",
    ".cache/**"
  ]
}
